#include <stdio.h>

int main() {
   int n,m,i,j;
   int num,count =0;
   printf("enter number to find frequency");
   scanf("%d",&num);
   printf("enter rows\n");
   scanf("%d",&n);
   printf("enter columns\n");
   scanf("%d",&m);
   int a[n][m];
   printf("enter array elements\n");
   for(i=0;i<n;i++)
   {
       for(j=0;j<m;j++)
       {
           scanf("%d",&a[i][j]);
       }
   }
    for(i=0;i<n;i++)
   {
       for(j=0;j<m;j++)
       {
         if(num==a[i][j])
         {
             count++;
         }
       }
   }
   printf("frequency of %d in matrix is %d",num,count);

    return 0;
}
