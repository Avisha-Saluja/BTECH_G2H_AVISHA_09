#include <stdio.h>

int main() {
   int n,m,i,j,sum=0;
   printf("enter number of rows\n");
   scanf("%d",&n);
   printf("enter number of coloumns\n");
   scanf("%d",&m);
   int A[n][m];
   printf("enter array elements\n");
   for(i=0;i<n;i++)
   {
       for(j=0;j<m;j++)
       {
           scanf("%d",&A[i][j]);
       }
   }
   for(i=0;i<n;i++)
   {
       for(j=0;j<m;j++)
       {
           if(i==0||i==n-1||j==0||j==m-1)
           {
               sum=sum+A[i][j];
           }
       }
   }
   printf("sum of boundary elements is\n%d\n",sum);
}
