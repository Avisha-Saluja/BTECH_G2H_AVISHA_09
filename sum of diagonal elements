#include <stdio.h>

int main() {
   int n,m,i,j;
   int s=0;
   printf("enter rows\n");
   scanf("%d",&n);
   printf("enter columns\n");
   scanf("%d",&m);
   int a[n][m];
   printf("enter array elements\n");
   for(i=0;i<n;i++)
   {
       for(j=0;j<m;j++)
       {
           scanf("%d",&a[i][j]);
       }
   }
    for(i=0;i<n;i++)
   {
       for(j=0;j<m;j++)
       {
          if(i==j)
          {
              s=s+a[i][j];
          }
       }
   }
   printf("sum of diagonal element is \n %d",s);

    return 0;
}
