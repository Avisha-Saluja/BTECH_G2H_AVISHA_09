#include <stdio.h>

int main() {
    int n,i;
    int sum=0;
    printf("enter size of array\n");
    scanf("%d",&n);
    int a[n];
    printf("enter array elements\n");
    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    for(i=0;i<n;i++)
    {
        sum=sum+a[i];
    }
    printf("sum of array elements is %d", sum);
    
}
