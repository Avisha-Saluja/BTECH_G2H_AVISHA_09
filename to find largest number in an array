#include <stdio.h>

int main() {
    int n,i;
    printf("enter size of array\n");
    scanf("%d",&n);
    int a[n];
    printf("enter array elements\n");
    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    int max=a[0];
    for(i=0;i<n;i++)
    {
        if(a[i]>max)
        max=a[i];
    }
    printf("largest number is %d \n",max);
}
