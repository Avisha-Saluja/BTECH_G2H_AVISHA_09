#include <stdio.h>

int main() {
    int n,i;
    printf("enter size of array\n");
    scanf("%d",&n);
    int a[n];
    printf("enter array elements\n");
    for(i=0;i<n;i++)
    {
        scanf("%d",&a[i]);
    }
    printf("reversed array is \n");
    
    for(i=n-1;i>=0;i--)
    {
     printf("%d\n",a[i]);
    }
}
